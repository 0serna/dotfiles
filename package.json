{
  "name": "opencode-config",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "link": "tsx src/dotfiles-installer.ts",
    "check": "npm run lint && npm run typecheck && npm run test && npm run openspec",
    "format": "prettier --write .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "openspec": "openspec validate --all --no-interactive",
    "sync-pi-settings": "bash scripts/publish-pi-settings.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.75.4",
    "@earendil-works/pi-coding-agent": "^0.75.4",
    "@earendil-works/pi-tui": "^0.75.4",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.5.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown",
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  }
}
