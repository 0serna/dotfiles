{
  "name": "opencode-config",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "setup": "tsx src/installer.ts",
    "test": "vitest run",
    "check": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@opencode-ai/plugin": "^1.0.184",
    "@types/node": "^24.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "lint-staged": {
    "*.{ts,js,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
