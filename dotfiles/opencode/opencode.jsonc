{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "light",
  "agent": {
    "deep": {
      "mode": "primary",
      "color": "primary",
      "model": "openai/gpt-5.5",
      "variant": "medium",
    },
    "light": {
      "mode": "primary",
      "color": "secondary",
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max",
    },
    "explore": { "disable": true },
    "plan": { "disable": true },
    "build": { "disable": true },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
    },
    "context-mode": {
      "type": "local",
      "command": ["context-mode"],
    },
  },
  "plugin": ["@slkiser/opencode-quota@3.5.0", "context-mode@1.0.103"],
  "permission": {
    "*": "allow",
    "doom_loop": "ask",
    "bash": {
      "*": "allow",
      // help
      "* --help": "allow",
      "* --version": "allow",
      // system
      "chmod *": "ask",
      "chown *": "ask",
      "sudo *": "deny",
      // dependencies
      "apt *": "ask",
      "apt-get *": "ask",
      "brew *": "ask",
      "pip *": "ask",
      "pip3 *": "ask",
      "npm * -g *": "ask",
      "npm * --global *": "ask",
      // http
      "wget *": "ask",
      "curl *": "allow",
      "curl * POST *": "ask",
      "curl * PUT *": "ask",
      "curl * PATCH *": "ask",
      "curl * DELETE *": "ask",
      // git
      "git *": "ask",
      "git clone *": "allow",
      "git help *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git commit *": "allow",
      "git rev-parse *": "allow",
      "git remote -v": "allow",
      "git grep *": "allow",
      "git ls-files *": "allow",
      "git ls-tree *": "allow",
      "git blame *": "allow",
      "git check-ignore *": "allow",
      // gh
      "gh *": "ask",
      "gh help *": "allow",
      "gh search *": "allow",
      "gh status *": "allow",
      "gh release view *": "allow",
      "gh config get *": "allow",
      "gh config list *": "allow",
      "gh repo list *": "allow",
      "gh repo view *": "allow",
      "gh pr view *": "allow",
      "gh pr diff *": "allow",
      "gh pr list *": "allow",
      "gh pr status *": "allow",
      "gh pr checks *": "allow",
      "gh pr checkout *": "allow",
      "gh issue list *": "allow",
      "gh issue view *": "allow",
      "gh issue status *": "allow",
      "gh api *": "allow",
      "gh api * POST *": "ask",
      "gh api * PUT *": "ask",
      "gh api * PATCH *": "ask",
      "gh api * DELETE *": "ask",
    },
  },
  "lsp": true,
  "snapshot": false,
}
